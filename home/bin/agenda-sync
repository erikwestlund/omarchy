#!/bin/bash
# Sync agenda to cache file

CACHE_FILE="$HOME/.cache/agenda"
GCALCLI_BIN="$HOME/.bin/gcalcli"

if [[ ! -x "$GCALCLI_BIN" ]]; then
    GCALCLI_BIN="/usr/bin/gcalcli"
fi

"$GCALCLI_BIN" agenda \
    --calendar "Family" \
    --calendar "JHU" \
    --calendar "Personal" \
    --nostarted \
    --details=end \
    "$(date +%Y-%m-%d)" \
    "$(date -d '+7 days' +%Y-%m-%d)" \
    > "$CACHE_FILE" 2>/dev/null
