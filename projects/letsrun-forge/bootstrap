#!/bin/bash
# Bootstrap script for letsrun-forge
# Runs ansible to ensure project is ready to run

set -e

OMARCHY_DIR="$HOME/Omarchy"
MACHINE=$(cat ~/.machine 2>/dev/null || echo "laptop")

echo "Bootstrapping letsrun-forge..."

ANSIBLE_CONFIG="$OMARCHY_DIR/ansible/ansible.cfg" ansible-playbook \
    "$OMARCHY_DIR/ansible/playbook.yml" \
    --limit "$MACHINE" \
    --tags bootstrap \
    -e "project_name=letsrun-forge"

echo ""
echo "Bootstrap complete! Run 'llrf' to launch."
